<?xml version="1.0" encoding="UTF-8"?>
<configuration debug="false" scan="true" scanPeriod="30 seconds" packagingData="false">

    <springProperty name="LOG_HOME" source="logback.log-home"/>
    <springProperty name="LOG_NAME" source="logback.log-name"/>
    <springProperty name="LOG_PATTERN" source="logback.log-pattern"/>

    <!-- 导入logback类型 -->
    <import class="ch.qos.logback.core.ConsoleAppender"/>
    <import class="ch.qos.logback.core.rolling.RollingFileAppender"/>
    <import class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy"/>
    <import class="ch.qos.logback.classic.encoder.PatternLayoutEncoder"/>

    <!-- log精细配置 -->
    <logger name="io.github.yingzhuo.bayonet" level="trace"/>
    <logger name="org.springframework" level="warn"/>

    <appender name="STDOUT" class="ConsoleAppender">
        <encoder class="PatternLayoutEncoder">
            <pattern>[%d{yyyy-MM-dd HH:mm:ss.SSS}]%-5level %logger{72}[%L] - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="debug">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
